import { Palette } from "std-widgets.slint";
import { FilledButton, Elevation } from "@material/material.slint";
import { BaseButton } from "@material/ui/components/base_button.slint";
import {
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialTypography,
} from "@material/material.slint";
import { TaskbarConfigSlint, ConfigSlint } from "shared-items.slint";

import { Workspace, Taskbar } from "components/taskbar.slint";
import {
    TrayRow,
    TrayContextMenu,
    TrayItemSlint,
    ContextMenuDataSlint,
} from "components/tray.slint";
import { ProfilesRow } from "components/profiles.slint";
import {
    BatteryButton,
    BatteryDataSlint,
    BatteryPopup,
} from "components/battery.slint";
import {
    VolumeButton,
    VolumeDataSlint,
} from "components/volume.slint";
import {
    BrightnessButton,
} from "components/brightness.slint";

import { MaterialStyleMetrics } from "material-1.0/material.slint";

export struct TimeDataSlint { hour: int, minute: int }
export struct DateDataSlint { day: int, month: int, year: int }
export struct StringDateDataSlint { day: string, month: string, year: string }

export component barWindow inherits Window {
    in property <[Workspace]> workspaces;
    in property <[TrayItemSlint]> tray;
    in property <[BatteryDataSlint]> batteryData;
    in-out property <ContextMenuDataSlint> trayMenu;
    in property <int> brightness;
    in property <VolumeDataSlint> volumeData;
    in property <string> powerProfile;
    in property <string> fanProfile;

    in property <TimeDataSlint> timeData;
    in property <DateDataSlint> dateData;
    in property <StringDateDataSlint> stringDateData;

    property <bool> batteryPopupVis;

    in property <ConfigSlint> config;
    in-out property <length> window_width <=> self.width;
    in-out property <length> window_height <=> self.height;

    default-font-size: 10px;
    background: transparent;

    callback run_command(string);

    callback set_volume(int, int);
    callback set_muted(bool);
    callback set_brightness(int, int);
    callback set_power_profile(string);
    callback set_fan_profile(string);

    callback tray_item_clicked(string, string, length);
    callback menu_action_executed(string, string);

    callback manage_touch(string, bool);

    public function init_ui() {
        trayMenu.x-pos = layRight.x;
    }

    layLeft := HorizontalLayout {
        y: 0px;
        x: 0px;
        width: rectLeft.preferred-width;
        height: config.window.bar-height;
        rectLeft := Rectangle {

            background: MaterialPalette.surface_container;
            border-bottom-right-radius: MaterialStyleMetrics.border_radius_16;

            Path {
                width: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                height: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                y: 0px;
                x: rectLeft.width;
                fill: MaterialPalette.surface_container;
                commands: "M 7 8 L 7 3 L 12 3 C 9 4 8 5 7 8";
            }

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 2px;
                padding-bottom: 2px;
                spacing: MaterialStyleMetrics.spacing_2;
                battButton := BatteryButton {
                    battery_clicked() => {
                        root.batteryPopupVis = !root.batteryPopupVis;
                    }

                    battery: batteryData[0];
                }

                ProfilesRow {
                    set_power_profile(profile) => {
                        set_power_profile(profile);
                        set_fan_profile(profile)
                    }
                    powerProfile: powerProfile;
                }
            }
        }
    }

    layRight := HorizontalLayout {
        y: 0px;
        x: root.window_width - self.width;
        width: rectRight.preferred-width;
        height: config.window.bar-height;
        rectRight := Rectangle {
            height: 100%;

            background: MaterialPalette.surface_container;
            border-bottom-left-radius: MaterialStyleMetrics.border_radius_16;

            Path {
                width: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                height: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                y: 0px;
                x: -self.width;
                fill: MaterialPalette.surface_container;
                fill-rule: evenodd;
                commands: "M 7 3 L 12 3 L 12 8 C 11 5 10 4 7 3";
            }

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                padding-top: 2px;
                padding-bottom: 2px;
                spacing: MaterialStyleMetrics.spacing_2;

                TrayRow {
                    config: config.tray;
                    items: root.tray;
                    item_clicked(id, btn, button_x) => {
                        root.tray_item_clicked(id, btn, button_x + rectRight.x + layRight.x);
                    }
                }

                VolumeButton {
                    volume: volumeData;
                    volume_right_clicked() => {
                        set_muted(!volumeData.muted);
                    }
                    volume_scroll_up() => {
                        set_volume(volumeData.volume,config.interaction.volume-scroll-step)
                    }
                    volume_scroll_down() => {
                        set_volume(volumeData.volume,-config.interaction.volume-scroll-step)
                    }
                }

                BrightnessButton {
                    brightness: brightness;
                    brightness_scroll_up() => {
                        set_brightness(brightness,config.interaction.brightness-scroll-step)
                    }
                    brightness_scroll_down() => {
                        set_brightness(brightness, -config.interaction.brightness-scroll-step)
                    }
                }
            }
        }
    }

    HorizontalLayout {
        x: 0px;
        y: 0px;
        width: 100%;
        height: config.window.bar-height;
        alignment: center;
        Rectangle {
            width: 100%;

            rectMiddle := Rectangle {
                width: layoutMiddle.preferred-width;
                background: MaterialPalette.surface_container;
                border-bottom-left-radius: MaterialStyleMetrics.border_radius_16;
                border-bottom-right-radius: MaterialStyleMetrics.border_radius_16;

                Path {
                    width: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                    height: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                    y: 0px;
                    x: -self.width + 1px;
                    fill: MaterialPalette.surface_container;
                    fill-rule: evenodd;
                    commands: "M 7 3 L 12 3 L 12 8 C 11 5 10 4 7 3";
                }

                Path {
                    width: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                    height: (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16;
                    y: 0px;
                    x: rectMiddle.width - 1px;
                    fill: MaterialPalette.surface_container;
                    commands: "M 7 8 L 7 3 L 12 3 C 9 4 8 5 7 8";
                }

                layoutMiddle := HorizontalLayout {
                    y: 0px;
                    x: 0px;
                    width: 100%;
                    alignment: center;
                    padding-left: 15px;
                    padding-right: 15px;
                    padding-top: 2px;
                    VerticalLayout {
                        alignment: center;
                        spacing: -3px;

                        Text {
                            vertical-alignment: bottom;
                            horizontal-alignment: center;
                            text: (root.timeData.hour < 10 ? "0" : "") + root.timeData.hour + ":" + (root.timeData.minute < 10 ? "0" : "") + root.timeData.minute;
                            font-size: MaterialTypography.title_small.font-size;
                            font-weight: MaterialTypography.title_small.font-weight;
                        }

                        Text {
                            vertical-alignment: top;
                            horizontal-alignment: center;
                            text: root.stringDateData.day + ": " + root.stringDateData.month + " " + root.dateData.day;
                            font-size: MaterialTypography.label_small.font-size * 1;
                            font-weight: MaterialTypography.label_small.font-weight * 1;
                        }
                    }
                }
            }
        }
    }

    HorizontalLayout {
        y: 0px;
        x: 0px;
        width: 100%;
        height: config.window.bar-height;
        alignment: center;
        Taskbar {
            config: config;
            animation_multiplier: config.interaction.animation-multiplier;
            workspaces: workspaces;
            dispatch_command(cmd) => {
                root.run_command(cmd);
            }
        }
    }

    TouchArea {
        width: 100%;
        height: 100%;
        y: config.window.bar-height;

        clicked => {
            root.trayMenu.visible = false;
            root.batteryPopupVis = false;
        }
    }

    TrayContextMenu {
        x: root.trayMenu.x-pos - self.width / 2;
        y: config.window.bar-height + 4px;
        config: config.tray;
        menuData: root.trayMenu;
        animation_multiplier: config.interaction.animation-multiplier;
        changed menuData => {
            root.manage_touch("TrayMenu",root.trayMenu.visible);
        }

        menu_action_executed(item_id, action_id) => {
            root.menu_action_executed(item_id, action_id);
        }
    }

    BatteryPopup {
        x: battButton.x + rectLeft.x + layLeft.x;
        y: config.window.bar-height + 4px;
        config: config;
        fanProfile: root.fanProfile;
        powerProfile: root.powerProfile;
        animation_multiplier: config.interaction.animation-multiplier;
        popup_visible: root.batteryPopupVis;
        changed popup_visible => {
            root.manage_touch("BatteryPopup",root.batteryPopupVis);
        }

        set_power_profile(profile) => {
            root.set_power_profile(profile);
        }
        set_fan_profile(profile) => {
            root.set_fan_profile(profile);
        }
    }

    Path {
        width: 10px;
        height: 10px;
        y: config.window.bar-height;
        x: window_width - self.width;
        fill: MaterialPalette.surface_container;
        fill-rule: evenodd;
        commands: "M 7 3 L 12 3 L 12 8 C 11 5 10 4 7 3";
    }

    Path {
        width: 10px;
        height: 10px;
        y: config.window.bar-height;
        x: 0px;
        fill: MaterialPalette.surface_container;
        fill-rule: evenodd;
        commands: "M 7 8 L 7 3 L 12 3 C 9 4 8 5 7 8";
    }
}
