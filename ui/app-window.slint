import { HorizontalBox, Button } from "std-widgets.slint";
import { Palette } from "std-widgets.slint";

import { FilledButton } from "@material/material.slint";
import { MaterialPalette } from "@material/material.slint";
import { MaterialScheme } from "@material/material.slint";
import { MaterialSchemes } from "@material/material.slint";
import {
    MaterialTypography,
    MaterialStyleMetrics,
} from "@material/material.slint";



export { MaterialPalette }
export { MaterialScheme }
export { MaterialSchemes }

import { Workspace, Taskbar } from "components/taskbar.slint";


export component AppWindow inherits Window {
    height: 40px;
    in property <ColorScheme> color-scheme <=> Palette.color_scheme;

    in property <[Workspace]> workspaces;
    padding: 0px;
    in-out property <int> counter: 42;
    default-font-size: 10px;

    callback request-increase-value();
    callback run_command(string);

    Rectangle {
        width: 100%;
        height: 100%;

        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding: 0px;
            spacing: 0px;

            VerticalLayout {
                alignment: center;
                FilledButton {
                    text: "Increase value";
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            Taskbar {
                height: 70%;
                workspaces: workspaces;
                dispatch_command(cmd) => {
                    root.run_command(cmd);
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            VerticalLayout {
                alignment: center;
                FilledButton {
                    text: "Increase value";
                }
            }
        }
    }
}
