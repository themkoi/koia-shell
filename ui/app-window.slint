import { HorizontalBox, Button } from "std-widgets.slint";
import { Palette } from "std-widgets.slint";

import { FilledButton } from "@material/material.slint";
import { MaterialPalette } from "@material/material.slint";
import { MaterialScheme } from "@material/material.slint";
import { MaterialSchemes } from "@material/material.slint";
import {
    MaterialTypography,
    MaterialStyleMetrics,
} from "@material/material.slint";



export { MaterialPalette }
export { MaterialScheme }
export { MaterialSchemes }

import { Workspace, Taskbar } from "components/taskbar.slint";


export component AppWindow inherits Window {
    height: 40px;
    in property <ColorScheme> color-scheme <=> Palette.color_scheme;

    in property <[Workspace]> workspaces;
    padding: 0px;
    in-out property <int> counter: 42;
    default-font-size: 10px;

    callback request-increase-value();
    
    Rectangle {
        width: 100%;
        height: 100%;
        
        // Changed from HorizontalBox to HorizontalLayout to remove automatic padding
        HorizontalLayout {
            width: 100%;
            height: 100%;
            padding: 0px;   // Removes top/bottom/left/right spacing
            spacing: 0px;   // Removes spacing between layout elements

            Taskbar {
                // Ensure the Taskbar definition itself doesn't hardcode height: 80%
                height: 80%; 
                width: 50%;
                workspaces: workspaces;
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            // Wrapped Text in a layout or vertical centering if needed, 
            // since HorizontalLayout aligns items to the top by default
            VerticalLayout {
                alignment: center;
                Text {
                    text: "Counter: \{root.counter}";
                }
            }

            Rectangle {
                horizontal-stretch: 1;
            }

            VerticalLayout {
                alignment: center;
                FilledButton {
                    text: "Increase value";
                }
            }
        }
    }
}