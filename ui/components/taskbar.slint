import {
    Elevation,
    ScrollView,
    MaterialPalette,
    MaterialTypography,
    MaterialStyleMetrics,
    ToolTip,
} from "@material/material.slint";
import { BaseButton } from "@material/ui/components/base_button.slint";
import { MaterialText, MaterialPalette } from "../material-1.0/material.slint";
import { ConfigSlint } from "../shared-items.slint";
import {
    MaterialStyleMetrics,
} from "../material-1.0/ui/styling/material_style_metrics.slint";

export struct Window {
    id: int,
    app_id: string,
    title: string,
    icon: image,
    is_focused: bool,
}

export struct Workspace {
    id: int,
    windows: [Window],
}

export component Taskbar inherits Rectangle {
    in-out property <[Workspace]> workspaces;
    in property <ConfigSlint> config;
    in property <float> animation_multiplier;
    
    in property <length> indicator_max_width: 1500px; 
    in property <length> taskbar_max_width: 1000px;

    callback dispatch_command(string);

    out property <bool> is_expanded: touch.has-hover;

    height: is_expanded ? config.window.bar-height : 7px;

    animate height {
        duration: 100ms * animation_multiplier;
        easing: ease-in-out;
    }

    touch := TouchArea {
        width: is_expanded ? clamp(taskLay.preferred-width,0px,taskbar_max_width) + 40px : clamp(indicatorRect.preferred-width,0px,indicator_max_width);
        height: 100%;

        init-layout := VerticalLayout {
            height: 100%;
            width: 100%;

            HorizontalLayout {
                alignment: center;
                
                Rectangle {
                    width: 100%;
                    height: is_expanded ? config.window.bar-height : 0px;

                    animate width {
                        duration: 150ms * animation_multiplier;
                        easing: ease-in-out;
                    }
                    animate height {
                        duration: 100ms * animation_multiplier;
                        easing: ease-in-out;
                    }

                    Path {
                        width: is_expanded ? (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16 : 0px;
                        height: is_expanded ? (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16 : 0px;
                        y: 0px;
                        x: -self.width;
                        animate height {
                            duration: 100ms * animation_multiplier;
                            easing: ease-in-out;
                        }
                        animate width {
                            duration: 100ms * animation_multiplier;
                            easing: ease-in-out;
                        }

                        fill: MaterialPalette.surface_container;
                        fill-rule: evenodd;
                        commands: "M 7 3 L 12 3 L 12 8 C 11 5 10 4 7 3";
                    }

                    Path {
                        width: is_expanded ? (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16 : 0px;
                        height: is_expanded ? (config.window.bar-height + 3px) - MaterialStyleMetrics.border_radius_16 : 0px;
                        y: 0px;
                        x: taskRect.width;
                        animate height {
                            duration: 100ms * animation_multiplier;
                            easing: ease-in-out;
                        }
                        animate width {
                            duration: 100ms * animation_multiplier;
                            easing: ease-in-out;
                        }
                        fill: MaterialPalette.surface_container;
                        commands: "M 7 8 L 7 3 L 12 3 C 9 4 8 5 7 8";
                    }

                    taskRect := Rectangle {
                        background: MaterialPalette.surface_container;
                        border-bottom-left-radius: MaterialStyleMetrics.border_radius_16;
                        border-bottom-right-radius: MaterialStyleMetrics.border_radius_16;

                        HorizontalLayout {
                            padding-left: 20px;
                            padding-right: 20px;
                            padding-bottom: 2px;
                            scroll := ScrollView {
                                overlay_scrollbars: true;
                                horizontal_scroll: true;

                                taskLay := HorizontalLayout {
                                    alignment: center;
                                    height: 100%;
                                    spacing: 4px;
                                    padding-left: 8px;
                                    padding-right: 8px;

                                    for ws[i] in root.workspaces: Rectangle {
                                        border_radius: MaterialStyleMetrics.border_radius_28;
                                        background: MaterialPalette.surface_bright;
                                        height: 100%;
                                        width: layout.preferred-width;

                                        layout := HorizontalLayout {
                                            height: 100%;
                                            spacing: 4px;
                                            padding: 2px;

                                            for win[j] in ws.windows: Rectangle {
                                                height: 100%;
                                                width: base.preferred-width;

                                                callback clicked <=> base.clicked;

                                                accessible-role: button;
                                                accessible-enabled: win.is_focused;
                                                accessible-action-default => {
                                                    base.clicked();
                                                }

                                                elevation := Elevation {
                                                    border_radius: MaterialStyleMetrics.border_radius_28;
                                                    background: MaterialPalette.primary;
                                                    width: 100%;
                                                    height: 100%;
                                                }

                                                base := BaseButton {
                                                    icon: win.icon;
                                                    icon-size: config.taskbar.icon-size;

                                                    icon_color: transparent;
                                                    border_radius: elevation.border_radius;
                                                    color: MaterialPalette.on_primary;
                                                    height: 100%;
                                                    button_horizontal_padding: 3px;

                                                    pointer-event(event) => {
                                                        if (event.kind == PointerEventKind.up) {
                                                            if (event.button == PointerEventButton.left) {
                                                                dispatch_command("niri msg action focus-window --id \{win.id}");
                                                            }
                                                            if (event.button == PointerEventButton.middle) {
                                                                dispatch_command("niri msg action close-window --id \{win.id}");
                                                            }
                                                        }
                                                    }
                                                }

                                                states [
                                                    disabled when !win.is_focused: {
                                                        elevation.background: transparent;
                                                        base.color: MaterialPalette.on_surface;
                                                    }
                                                    hover when base.has_hover && !base.pressed && !base.enter_pressed: {
                                                        elevation.level: 2;
                                                    }
                                                ]
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            HorizontalLayout {
                alignment: center;
                
                Rectangle {
                    width: 100%;                    
                    background: rgba(
                        MaterialPalette.surface_tint.red,
                        MaterialPalette.surface_tint.green,
                        MaterialPalette.surface_tint.blue,
                        0.25
                    );
                    height: 7px;
                    opacity: !is_expanded ? 1.0 : 0.0;

                    animate opacity {
                        duration: 100ms * animation_multiplier;
                        easing: ease-in-out;
                    }

                    border-top-left-radius: 0px;
                    border-top-right-radius: 0px;
                    border-bottom-left-radius: MaterialStyleMetrics.border_radius_16;
                    border-bottom-right-radius: MaterialStyleMetrics.border_radius_16;
                    clip:true;
                    
                    ScrollView {
                        width: 100%;
                        height: 100%;
                        horizontal_scroll: true;
                        overlay_scrollbars: true; 
                        hide_scrollbars: true;

                        indicatorRect :=  HorizontalLayout {
                            spacing: 10px;
                            alignment: center;
                            
                            for ws[i] in root.workspaces: Rectangle {
                                background: MaterialPalette.surface_container;
                                height: 7px;
                                y: 0px;

                                border-top-left-radius: 0px;
                                border-top-right-radius: 0px;
                                border-bottom-left-radius: MaterialStyleMetrics.border_radius_16;
                                border-bottom-right-radius: MaterialStyleMetrics.border_radius_16;

                                HorizontalLayout {
                                    padding-left: 3px;
                                    padding-right: 3px;
                                    padding-bottom: 0px;
                                    padding-top: 0px;
                                    spacing: 3px;
                                    height: 100%;

                                    for win[j] in ws.windows: Rectangle {
                                        width: win.is_focused ? 25px : 17px;
                                        height: 5px;
                                        background: win.is_focused ? MaterialPalette.primary : MaterialPalette.surface_variant;
                                        animate width {
                                            duration: 1000ms * animation_multiplier;
                                            easing: ease-in-out;
                                        }

                                        border-top-left-radius: 0px;
                                        border-top-right-radius: 0px;
                                        border-bottom-left-radius: MaterialStyleMetrics.border_radius_16;
                                        border-bottom-right-radius: MaterialStyleMetrics.border_radius_16;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}