import {
    Elevation,
    ScrollView,
    MaterialPalette,
    MaterialTypography,
    MaterialStyleMetrics,
    CheckBox,
    RadioButton,
    CheckState,
    VerticalDivider,
} from "@material/material.slint";
import { BaseButton } from "@material/ui/components/base_button.slint";

export struct VolumeDataSlint { volume: int, muted: bool}
export struct TrayItemSlint { id: string, title: string, icon: image, status: string, active: bool}
export struct ContextMenuActionSlint {
    id: string,
    label: string,
    icon: image,
    has_icon: bool,
    is_destructive: bool,
    is_separator: bool,
    toggle_state: int,
    depth: int
}
export struct ContextMenuDataSlint {
    visible: bool,
    item_id: string,
    title: string,
    x_pos: length,
    actions: [ContextMenuActionSlint]
}
export struct DataSlint {
    volumeData: VolumeDataSlint,
    brightness: int,
    tray-items: [TrayItemSlint],
    menuData: ContextMenuDataSlint
}

export component TrayItem inherits Rectangle {
    in property <TrayItemSlint> item;
    in property <length> icon-size;
    background: item.active ? MaterialPalette.secondary : MaterialPalette.surface_variant;
    border_radius: MaterialStyleMetrics.border_radius_8;
    padding: MaterialStyleMetrics.padding_8;

    Image {
        source: root.item.icon;
        width: root.icon-size;
        height: root.icon-size;
    }
}

// 1. Status Icon Strip Layout
export component TrayRow inherits Rectangle {
    in property <[TrayItemSlint]> items;
    in-out property <DataSlint> shared-data;
    callback item_clicked(string, string);

    HorizontalLayout {
        padding: MaterialStyleMetrics.padding_8;
        spacing: 4px;

        for tray-item in root.items: Rectangle {
            border_radius: MaterialStyleMetrics.border_radius_8;

            elevation := Elevation {
                border_radius: parent.border_radius;
                background: tray-item.active ? MaterialPalette.secondary_container : transparent;
            }

            base := BaseButton {
                width: 100%;
                height: 100%;
                border_radius: parent.border_radius;
                icon: tray-item.icon;
                icon-size: 20px;
                icon_color: transparent;

                pointer-event(event) => {
                    if (event.button == PointerEventButton.left) {
                        root.item_clicked(tray-item.id, "left");
                    } else if (event.button == PointerEventButton.right) {
                        root.item_clicked(tray-item.id, "right");
                    }
                }
            }

            states [
                hover when base.has_hover && !base.pressed: {
                    elevation.level: 1;
                    elevation.background: tray-item.active ? MaterialPalette.secondary_container : MaterialPalette.surface_container_highest;
                }
            ]
        }
    }
}

// 2. Corrected Menu Overlay Popup
export component TrayContextMenu inherits Rectangle {
    in property <ContextMenuDataSlint> menu-data;
    in property <length> bar-height;
    in property <length> parent-absolute-x;
    callback menu_action_executed(string, string);

    elevation := Elevation {
        level: 2;
        border_radius: MaterialStyleMetrics.border_radius_8;
        background: MaterialPalette.surface_container_low;
        width: 100%;
        height: 100%;

        layout := VerticalLayout {
            padding: MaterialStyleMetrics.padding_8;

            Text {
                text: root.menu-data.title;
                font-size: MaterialTypography.body_small.font_size;
                color: MaterialPalette.on_surface_variant;
                horizontal-alignment: center;
                height: 25px;
            }

            Rectangle {
                height: 1px;
                background: MaterialPalette.outline_variant;
            }

            ScrollView {
                has-focus: true;

                VerticalLayout {
                    spacing: 4px;
                    padding-top: 4px;

                    for action in root.menu-data.actions: VerticalLayout {
                        if action.is_separator: Rectangle {
                            height: 9px;
                            padding-top: 4px;
                            padding-bottom: 4px;
                            VerticalDivider {
                                width: 100%;
                                height: 1px;
                            }
                        }

                        if !action.is_separator: Rectangle {
                            height: 28px;
                            border_radius: MaterialStyleMetrics.border_radius_28;

                            item_elevation := Elevation {
                                border_radius: parent.border_radius;
                                background: transparent;
                                width: 100%;
                                height: 100%;
                            }

                            Rectangle {
                                width: 100%;
                                height: 100%;

                                if action.depth > 0: Rectangle {
                                    x: 4px + (action.depth * 8px);
                                    width: 1.5px;
                                    height: 75%;
                                    background: MaterialPalette.outline.with_alpha(40%);
                                }

                                HorizontalLayout {
                                    padding-left: 8px + (action.depth * 14px);
                                    spacing: 8px;
                                    alignment: start;

                                    if action.toggle_state != 0: Rectangle {
                                        width: 24px;
                                        height: 100%;

                                        if action.toggle_state == 2 || action.toggle_state == 3: CheckBox {
                                            check_state: action.toggle_state == 2 ? CheckState.checked : CheckState.unchecked;
                                            enabled: false;
                                        }
                                        if action.toggle_state == 4: RadioButton {
                                            checked: true;
                                            enabled: false;
                                        }
                                    }

                                    if action.has_icon: VerticalLayout {
                                        alignment: center;
                                        Image {
                                            source: action.icon;
                                            width: 14px;
                                            height: 14px;
                                        }
                                    }

                                    Text {
                                        text: action.label;
                                        color: action.is_destructive ? MaterialPalette.error : MaterialPalette.on_surface;
                                        font-size: MaterialTypography.label_medium.font-size;
                                        font-weight: action.depth > 0 ? MaterialTypography.label_small.font_weight : MaterialTypography.label_medium.font_weight;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            base_item := BaseButton {
                                width: 100%;
                                height: 100%;
                                border_radius: parent.border_radius;
                                color: transparent;
                                clicked => {
                                    root.menu_action_executed(root.menu-data.item_id, action.id);
                                }
                            }

                            states [
                                hover when base_item.has_hover: {
                                    item_elevation.background: MaterialPalette.surface_container_highest;
                                }
                            ]
                        }
                    }
                }
            }
        }
    }
}
