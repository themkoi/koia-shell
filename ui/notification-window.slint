import {
    FilledButton,
    FilledIconButton,
    MaterialPalette,
    MaterialTypography,
} from "@material/material.slint";
import { ConfigSlint } from "shared-items.slint";
import { MaterialStyleMetrics } from "material-1.0/ui/styling/material_style_metrics.slint";

export struct ActionData {
    key: string,
    label: string,
}

export struct NotifData {
    id: int,
    id_rust: int,
    app-name: string,
    title: string,
    subtitle: string,
    message: string,
    timeout: int,
    icon: image,
    actions: [ActionData],
}

export component NotificationCard inherits Rectangle {
    in-out property <NotifData> data;
    in property <length> icon-size;
    in property <length> max-card-height: 200px;
    
    // Dynamic animation scale factor
    in property <float> animation-multiplier: 1.0;

    in property <length> absolute-x;
    in property <length> absolute-y;

    callback update_region(length, length, length, length);
    callback remove_region(length, length, length, length);
    callback release();
    callback action_clicked(string);

    private property <bool> i-alive: data.id >= 0;
    private property <int> last-id: -99;
    private property <float> life: 1.0;

    private property <length> active-reg-x: 0px;
    private property <length> active-reg-y: 0px;
    private property <length> active-reg-w: 0px;
    private property <length> active-reg-h: 0px;
    private property <bool> is-registered: false;
    private property <bool> pending-register: false;

    background: MaterialPalette.surface_container_high;
    border-radius: 12px;
    clip: true;
    border-width: 1px;
    border-color: i-alive ? MaterialPalette.outline_variant : transparent;
    
    opacity: root.i-alive ? 1.0 : 0.0;

    animate y { duration: 250ms * root.animation-multiplier; easing: ease-in-out-back; }
    animate height { duration: 200ms * root.animation-multiplier; easing: ease-in-out-back; }
    animate opacity { duration: 400ms * root.animation-multiplier; easing: ease-in-out; }

    changed i-alive => {
        if (root.i-alive && !root.is-registered && !root.pending-register) {
            root.pending-register = true;
        }
    }

    changed absolute-y => {
        if (root.i-alive && root.is-registered && root.width > 0px && root.height > 0px) {
            root.remove_region(root.active-reg-x, root.active-reg-y, root.active-reg-w, root.active-reg-h);
            root.active-reg-x = root.absolute-x;
            root.active-reg-y = root.absolute-y;
            root.active-reg-w = root.width;
            root.active-reg-h = root.height;
            root.update_region(root.active-reg-x, root.active-reg-y, root.active-reg-w, root.active-reg-h);
        }
    }

    changed data => {
        if (data.id != last-id) {
            last-id = data.id;
            if (data.id >= 0) {
                i-alive = true;
                life = 1.0;
            }
        }
    }

    Timer {
        interval: 50ms;
        running: root.pending-register && root.width > 0px && root.height > 0px;
        triggered => {
            if (root.absolute-x >= 0px && root.absolute-y >= 0px) {
                root.active-reg-x = root.absolute-x;
                root.active-reg-y = root.absolute-y;
                root.active-reg-w = root.width;
                root.active-reg-h = root.height;
                root.update_region(root.active-reg-x, root.active-reg-y, root.active-reg-w, root.active-reg-h);
                root.is-registered = true;
                root.pending-register = false;
            }
        }
    }

    Timer {
        interval: 100ms;
        running: root.i-alive && root.data.timeout > 0;
        triggered => {
            root.life = max(0.0, root.life - (0.1 / (root.data.timeout * 1.0)));
            if (root.life <= 0.0 && root.i-alive) {
                if (root.is-registered) {
                    root.remove_region(root.active-reg-x, root.active-reg-y, root.active-reg-w, root.active-reg-h);
                    root.is-registered = false;
                }
                root.i-alive = false;
                root.release();
            }
        }
    }

    VerticalLayout {
        padding: MaterialStyleMetrics.padding_14;
        spacing: MaterialStyleMetrics.spacing_6;

        HorizontalLayout {
            spacing: 12px;

            Rectangle {
                horizontal-stretch: 1;

                HorizontalLayout {
                    spacing: 12px;

                    VerticalLayout {
                        alignment: center;
                        if root.data.icon.width > 0 && root.data.icon.height > 0: Image {
                            source: root.data.icon;
                            width: root.icon-size;
                            height: self.width;
                            image-fit: contain;
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        max-height: root.max-card-height - 32px;

                        Text {
                            text: data.app-name;
                            font-size: MaterialTypography.body_small.font-size;
                            font-weight: MaterialTypography.body_small.font-weight;
                            color: MaterialPalette.on_surface_variant;
                        }

                        Text {
                            text: data.title;
                            font-size: MaterialTypography.title_medium.font-size;
                            font-weight: MaterialTypography.title_medium.font-weight;
                            color: MaterialPalette.on_surface;
                            wrap: word-wrap;
                        }

                        if data.subtitle != "": Text {
                            text: data.subtitle;
                            font-size: MaterialTypography.body_medium.font-size;
                            color: MaterialPalette.on_surface_variant;
                            wrap: word-wrap;
                        }

                        Text {
                            text: data.message;
                            font-size: MaterialTypography.body_medium.font-size;
                            color: MaterialPalette.on_surface_variant;
                            wrap: word-wrap;
                        }
                    }
                }

                TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => { root.action_clicked("default"); }
                }
            }

            VerticalLayout {
                alignment: start;
                FilledIconButton {
                    icon: @image-url("./assets/close.svg");
                    clicked => {
                        if (root.i-alive) {
                            if (root.is-registered) {
                                root.remove_region(root.active-reg-x, root.active-reg-y, root.active-reg-w, root.active-reg-h);
                                root.is-registered = false;
                            }
                            root.i-alive = false;
                            root.release();
                        }
                    }
                }
            }
        }

        if data.actions.length > 0: HorizontalLayout {
            spacing: 8px;
            alignment: start;
            for act in data.actions: VerticalLayout {
                if act.key != "default": FilledButton {
                    text: act.label;
                    clicked => { root.action_clicked(act.key); }
                }
            }
        }
    }
}

export component notificationWindow inherits Window {
    in property <ConfigSlint> config;
    in-out property <length> window_height <=> self.height;

    background: transparent;
    default-font-size: 10px;

    Rectangle {
        width: root.card-width + (root.pad * 2);
        height: root.height;
        x: root.width - self.width;
        background: transparent;
    }

    property <int> nid: 0;
    property <length> pad: 16px;
    property <length> card-width: config.notification.notification-width;
    property <length> cx: root.width - card-width - root.pad;

    private property <length> h0: slots[0].id >= 0 ? min(config.notification.notification_max_height, cards.c0-pref) : 0px;
    private property <length> h1: slots[1].id >= 0 ? min(config.notification.notification_max_height, cards.c1-pref) : 0px;
    private property <length> h2: slots[2].id >= 0 ? min(config.notification.notification_max_height, cards.c2-pref) : 0px;
    private property <length> h3: slots[3].id >= 0 ? min(config.notification.notification_max_height, cards.c3-pref) : 0px;

    property <[NotifData]> slots: [
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] },
    ];

    pure function calculate_y(idx: int) -> length {
        let y0 = root.pad;
        let y1 = y0 + (idx > 0 && root.slots[0].id >= 0 ? root.h0 + 8px : 0px);
        let y2 = y1 + (idx > 1 && root.slots[1].id >= 0 ? root.h1 + 8px : 0px);
        let y3 = y2 + (idx > 2 && root.slots[2].id >= 0 ? root.h2 + 8px : 0px);
        let y4 = y3 + (idx > 3 && root.slots[3].id >= 0 ? root.h3 + 8px : 0px);
        return y4;
    }

    callback add-notif(int, string, string, string, string, int, image, [ActionData]);
    callback a_input_region(int, int, int, int);
    callback r_input_region(int, int, int, int);
    callback noti-close(int);
    callback noti-action(int, string);

    add-notif(id_rust, app_name, title, subtitle, msg, timeout, icon_img, acts) => {
        if (root.slots[0].id < 0) { root.slots[0] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: icon_img, actions: acts }; }
        else if (root.slots[1].id < 0) { root.slots[1] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: icon_img, actions: acts }; }
        else if (root.slots[2].id < 0) { root.slots[2] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: icon_img, actions: acts }; }
        else if (root.slots[3].id < 0) { root.slots[3] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: icon_img, actions: acts }; }
        else if (root.slots[4].id < 0) { root.slots[4] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: icon_img, actions: acts }; }
        nid += 1;
    }

    cards := Rectangle {
        width: 100%;
        height: 100%;

        out property <length> c0-pref: c0.preferred-height;
        out property <length> c1-pref: c1.preferred-height;
        out property <length> c2-pref: c2.preferred-height;
        out property <length> c3-pref: c3.preferred-height;

        c0 := NotificationCard {
            data: root.slots[0];
            x: root.cx;
            y: root.calculate_y(0);
            width: root.card-width;
            icon-size: config.notification.icon-size;
            max-card-height: config.notification.notification_max_height;
            animation-multiplier: root.config.interaction.animation-multiplier;
            height: self.data.id >= 0 ? min(config.notification.notification_max_height, self.preferred-height) : 0px;
            absolute-x: self.x;
            absolute-y: root.calculate_y(1);
            update_region(x, y, w, h) => { root.a_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            remove_region(x, y, w, h) => { root.r_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            action_clicked(k) => { root.noti-action(self.data.id_rust, k); }
            release => {
                root.noti-close(self.data.id_rust);
                root.slots[0] = { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] };
            }
        }

        c1 := NotificationCard {
            data: root.slots[1];
            x: root.cx;
            y: root.calculate_y(1);
            width: root.card-width;
            icon-size: config.notification.icon-size;
            max-card-height: config.notification.notification_max_height;
            animation-multiplier: root.config.interaction.animation-multiplier;
            height: self.data.id >= 0 ? min(config.notification.notification_max_height, self.preferred-height) : 0px;
            absolute-x: self.x;
            absolute-y: root.calculate_y(1);
            update_region(x, y, w, h) => { root.a_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            remove_region(x, y, w, h) => { root.r_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            action_clicked(k) => { root.noti-action(self.data.id_rust, k); }
            release => {
                root.noti-close(self.data.id_rust);
                root.slots[1] = { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] };
            }
        }

        c2 := NotificationCard {
            data: root.slots[2];
            x: root.cx;
            y: root.calculate_y(2);
            width: root.card-width;
            icon-size: config.notification.icon-size;
            max-card-height: config.notification.notification_max_height;
            animation-multiplier: root.config.interaction.animation-multiplier;
            height: self.data.id >= 0 ? min(config.notification.notification_max_height, self.preferred-height) : 0px;
            absolute-x: self.x;
            absolute-y: root.calculate_y(1);
            update_region(x, y, w, h) => { root.a_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            remove_region(x, y, w, h) => { root.r_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            action_clicked(k) => { root.noti-action(self.data.id_rust, k); }
            release => {
                root.noti-close(self.data.id_rust);
                root.slots[2] = { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] };
            }
        }

        c3 := NotificationCard {
            data: root.slots[3];
            x: root.cx;
            y: root.calculate_y(3);
            width: root.card-width;
            icon-size: config.notification.icon-size;
            max-card-height: config.notification.notification_max_height;
            animation-multiplier: root.config.interaction.animation-multiplier;
            height: self.data.id >= 0 ? min(config.notification.notification_max_height, self.preferred-height) : 0px;
            absolute-x: self.x;
            absolute-y: root.calculate_y(1);
            update_region(x, y, w, h) => { root.a_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            remove_region(x, y, w, h) => { root.r_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            action_clicked(k) => { root.noti-action(self.data.id_rust, k); }
            release => {
                root.noti-close(self.data.id_rust);
                root.slots[3] = { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] };
            }
        }

        c4 := NotificationCard {
            data: root.slots[4];
            x: root.cx;
            y: root.calculate_y(4);
            width: root.card-width;
            icon-size: config.notification.icon-size;
            max-card-height: config.notification.notification_max_height;
            animation-multiplier: root.config.interaction.animation-multiplier;
            height: self.data.id >= 0 ? min(config.notification.notification_max_height, self.preferred-height) : 0px;
            absolute-x: self.x;
            absolute-y: root.calculate_y(1);
            update_region(x, y, w, h) => { root.a_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            remove_region(x, y, w, h) => { root.r_input_region(x / 1px, y / 1px, w / 1px, h / 1px); }
            action_clicked(k) => { root.noti-action(self.data.id_rust, k); }
            release => {
                root.noti-close(self.data.id_rust);
                root.slots[4] = { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: @image-url(""), actions: [] };
            }
        }
    }
}