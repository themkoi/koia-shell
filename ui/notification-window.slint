import { Palette } from "std-widgets.slint";
import {
    FilledButton,
    MaterialPalette,
    MaterialScheme,
    MaterialSchemes,
    MaterialTypography,
    MaterialStyleMetrics,
} from "@material/material.slint";
import { ConfigSlint } from "shared-items.slint";

export struct ActionData {
    key: string,
    label: string,
}

export struct NotifData {
    id: int,
    id_rust: int,
    app-name: string,
    title: string,
    subtitle: string,
    message: string,
    timeout: int,
    icon: bool,
    actions: [ActionData],
}

export component NotificationCard inherits Rectangle {
    in-out property <NotifData> data;
    in property <length> parent-cx;
    in property <length> calculated-y;

    callback update_region(length, length, length);
    callback remove_region(length, length, length);
    callback release();
    callback action_clicked(string);

    private property <bool> i-alive: data.id >= 0;
    private property <int> last-id: -99;
    private property <float> life: 1.0;
    private property <bool> needs-init: false;
    
    private property <length> last-reg-x: 0px;
    private property <length> last-reg-y: 0px;
    private property <bool> is-registered: false;

    out property <bool> alive: i-alive;

    background: MaterialPalette.surface_container_high;
    border-radius: 12px;
    clip: true;
    border-width: 1px;
    border-color: i-alive ? MaterialPalette.outline_variant : transparent;

    changed calculated-y => {
        if (root.i-alive) {
            if (root.is-registered) {
                root.remove_region(root.last-reg-x, root.last-reg-y, 300px);
            }
            root.update_region(root.parent-cx, root.calculated-y, 300px);
            root.last-reg-x = root.parent-cx;
            root.last-reg-y = root.calculated-y;
            root.is-registered = true;
        }
    }

    changed data => {
        if (data.id != last-id) {
            last-id = data.id;
            if (data.id >= 0) {
                i-alive = true;
                life = 1.0;
                needs-init = true;
            }
        }
    }

    Timer {
        interval: 1ms;
        running: root.needs-init && root.i-alive;
        triggered => {
            root.needs-init = false;
            root.update_region(root.parent-cx, root.calculated-y, 300px);
            root.last-reg-x = root.parent-cx;
            root.last-reg-y = root.calculated-y;
            root.is-registered = true;
        }
    }

    Timer {
        interval: 100ms;
        running: root.i-alive && root.data.timeout > 0;
        triggered => {
            root.life = max(0.0, root.life - (0.1 / (root.data.timeout * 1.0)));
            if (root.life <= 0.0 && root.i-alive) {
                root.is-registered = false;
                root.remove_region(root.parent-cx, root.calculated-y, 300px);
                root.i-alive = false;
                root.release();
            }
        }
    }

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        HorizontalLayout {
            spacing: 12px;
            alignment: space-between;

            VerticalLayout {
                spacing: 4px;
                alignment: center;

                HorizontalLayout {
                    alignment: start;
                    Text {
                        text: data.app-name;
                        font-size: MaterialTypography.body_small.font-size;
                        font-weight: MaterialTypography.body_small.font-weight;
                        color: MaterialPalette.on_surface_variant;
                    }
                }

                Text {
                    text: data.title;
                    font-size: MaterialTypography.title_medium.font-size;
                    font-weight: MaterialTypography.title_medium.font-weight;
                    color: MaterialPalette.on_surface;
                }

                if data.subtitle != "": Text {
                    text: data.subtitle;
                    font-size: MaterialTypography.body_medium.font-size;
                    color: MaterialPalette.on_surface_variant;
                }

                Text {
                    text: data.message;
                    font-size: MaterialTypography.body_medium.font-size;
                    color: MaterialPalette.on_surface_variant;
                    wrap: word-wrap;
                }
            }

            VerticalLayout {
                alignment: start;

                FilledButton {
                    text: "✕";
                    clicked => {
                        if (root.i-alive) {
                            root.is-registered = false;
                            root.remove_region(root.parent-cx, root.calculated-y, 300px);
                            root.i-alive = false;
                            root.release();
                        }
                    }
                }
            }
        }

        if data.actions.length > 0: HorizontalLayout {
            spacing: 8px;
            alignment: start;
            for act in data.actions: FilledButton {
                text: act.label;
                clicked => {
                    root.action_clicked(act.key);
                }
            }
        }
    }
}

export component notificationWindow inherits Window {
    in property <ConfigSlint> config;
    in-out property <bool> new_notification: false;

    title: "Notification Demo";
    preferred-width: 950px;
    preferred-height: 830px;
    background: transparent;
    default-font-size: 10px;

    property <int> nid: 0;
    property <length> pad: 16px;
    property <length> stride: 300px;
    property <length> card-width: 300px;
    property <length> cx: root.width - card-width - root.pad;

    property <[NotifData]> slots: [
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: false, actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: false, actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: false, actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: false, actions: [] },
        { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: false, actions: [] },
    ];

    pure function calculate_y(idx: int) -> length {
        let y0 = root.pad;
        let y1 = y0 + (idx > 0 && root.slots[0].id >= 0 ? root.stride + 8px : 0px);
        let y2 = y1 + (idx > 1 && root.slots[1].id >= 0 ? root.stride + 8px : 0px);
        let y3 = y2 + (idx > 2 && root.slots[2].id >= 0 ? root.stride + 8px : 0px);
        let y4 = y3 + (idx > 3 && root.slots[3].id >= 0 ? root.stride + 8px : 0px);
        return y4;
    }

    callback add-notif(int, string, string, string, string, int, [ActionData]);
    callback a_input_region(int, int, int, int);
    callback r_input_region(int, int, int, int);
    callback noti-close(int);
    callback noti-action(int, string);

    add-notif(id_rust, app_name, title, subtitle, msg, timeout, acts) => {
        if (root.slots[0].id < 0) {
            root.slots[0] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: false, actions: acts };
        } else if (root.slots[1].id < 0) {
            root.slots[1] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: false, actions: acts };
        } else if (root.slots[2].id < 0) {
            root.slots[2] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: false, actions: acts };
        } else if (root.slots[3].id < 0) {
            root.slots[3] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: false, actions: acts };
        } else if (root.slots[4].id < 0) {
            root.slots[4] = { id: nid, id_rust: id_rust, app-name: app_name, title: title, subtitle: subtitle, message: msg, timeout: timeout, icon: false, actions: acts };
        }
        nid += 1;
    }

VerticalLayout {
        x: root.cx;
        y: root.pad;
        spacing: 8px;

        for card-data[index] in root.slots: NotificationCard {
            data: card-data;
            width: root.card-width;
            height: card-data.id >= 0 ? root.stride : 0px;
            visible: card-data.id >= 0;
            
            parent-cx: root.cx;
            calculated-y: root.calculate_y(index);

            update_region(reg-x, reg-y, reg-h) => {
                root.a_input_region(reg-x / 1px, reg-y / 1px, root.card-width / 1px, reg-h / 1px);
            }

            remove_region(reg-x, reg-y, reg-h) => {
                root.r_input_region(reg-x / 1px, reg-y / 1px, root.card-width / 1px, reg-h / 1px);
            }

            action_clicked(key) => {
                root.noti-action(root.slots[index].id_rust, key);
            }

            release => {
                root.noti-close(root.slots[index].id_rust);
                root.slots[index] = { id: -1, id_rust: -1, app-name: "", title: "", subtitle: "", message: "", timeout: 0, icon: false, actions: [] };
            }
        }
    }
}